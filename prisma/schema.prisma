// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Fixed, source-agnostic taxonomy (kept in sync with src/lib/categories.ts)
// used to group search results into sections regardless of which source an
// event came from.
enum EventCategory {
  MUSIC
  SPORTS
  COMEDY
  ARTS_THEATER
  FILM
  FOOD_DRINK
  COMMUNITY
  FAMILY
  LOCAL_VENUE
  OTHER
}

// Raw + normalized event data pulled from a source adapter (Ticketmaster, Eventbrite, Meetup, ...).
// sourceName + sourceEventId uniquely identifies an event within its origin API, used to dedupe on refresh.
model Event {
  id            String        @id @default(cuid())
  sourceName    String
  sourceEventId String
  title         String
  description   String?
  url           String
  startTime     DateTime
  endTime       DateTime?
  venueName     String?
  city          String?
  genre         String?
  category      EventCategory @default(OTHER)
  imageUrl      String?
  // IANA name (e.g. "America/Denver") for displaying times in the venue's
  // own local time rather than the server's; null when a source can't provide it.
  timezone      String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  savedEvent SavedEvent?

  @@unique([sourceName, sourceEventId])
  @@index([startTime])
  @@index([genre])
  @@index([city])
  @@index([category])
}

// An event the (single) user of this instance has chosen to add to their calendar.
// Presence of a row here is what makes an event show up in the generated iCal feed.
model SavedEvent {
  id      String   @id @default(cuid())
  eventId String   @unique
  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  savedAt DateTime @default(now())
}

// Singleton row holding instance-level config, notably the secret token used in the iCal feed URL.
model InstanceSettings {
  id        Int    @id @default(1)
  feedToken String @unique @default(cuid())
}

// A user-approved iCal feed for a specific local venue/organization, found via the
// "Discover Local Sources" flow and confirmed by the user before being trusted as a
// permanent event source. Scoped to a city so discovery/search stays geographically bounded.
model LocalFeedSource {
  id        String   @id @default(cuid())
  city      String
  url       String   @unique
  label     String
  addedAt   DateTime @default(now())

  @@index([city])
}

// A venue website the user has added for event tracking. The page is fetched
// and checked for LD+JSON schema.org Event objects on each search refresh.
// readable=false means no parseable events were found when it was added — the
// URL is still stored so it appears in the list as a quick link.
model VenueSource {
  id        String   @id @default(cuid())
  url       String   @unique
  label     String
  readable  Boolean  @default(false)
  addedAt   DateTime @default(now())
}

// Tracks, per source and per (city+genre+keyword) combination, the single
// contiguous date range already known to be fresh - so a search whose date
// range falls fully within it can skip re-hitting that source's API
// entirely, and one that partially overlaps only needs to fetch the union
// (not the whole requested range from scratch). Only used for explicit
// date-range searches; open-ended searches aren't tracked here.
model SearchCacheRange {
  id              String   @id @default(cuid())
  sourceName      String
  filterKey       String
  cachedStart     DateTime
  cachedEnd       DateTime
  lastRefreshedAt DateTime @default(now())

  @@unique([sourceName, filterKey])
}
