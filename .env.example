# Copy this file to .env and fill in your own values.
# When running via Docker Compose, "db" is the Postgres service name (not localhost).

DATABASE_URL="postgresql://gavin:gavin@db:5432/gavin_bot?schema=public"

# API keys for event sources. Get these free from each provider's developer portal:
#   Ticketmaster: https://developer.ticketmaster.com/
#   SeatGeek:     https://seatgeek.com/build (free client ID, no approval wait)
TICKETMASTER_API_KEY=""
SEATGEEK_CLIENT_ID=""

# "owner/repo" on GitHub, used to check for newer releases and show an update banner.
GITHUB_REPO="ebellino/GavinsCalendar"
